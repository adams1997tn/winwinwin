<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
const API = '/bet/public/api/agent_api.php';
const headers = { 'Content-Type': 'application/json', 'Bypass-Tunnel-Reminder': 'true' };

// ── TAB NAVIGATION ──
function showTab(name) {
    document.querySelectorAll('[id^="tab-"]').forEach(el => el.style.display = 'none');
    const tab = document.getElementById('tab-' + name);
    if (tab) tab.style.display = '';
    document.querySelectorAll('.sidebar-admin .nav-link').forEach(el => el.classList.remove('active'));
    event.target.closest('.nav-link')?.classList.add('active');

    if (name === 'pending') loadPending();
    if (name === 'history') loadHistory(null);
}

// ── CHART ──
const chartData = <?= json_encode($chart) ?>;
new Chart(document.getElementById('agentChart'), {
    type: 'bar',
    data: {
        labels: chartData.labels,
        datasets: [
            { label: 'Approved (€)', data: chartData.approved, backgroundColor: 'rgba(34,197,94,0.7)', borderRadius: 4 },
            { label: 'Rejected (€)', data: chartData.rejected, backgroundColor: 'rgba(239,68,68,0.5)', borderRadius: 4 }
        ]
    },
    options: {
        responsive: true,
        plugins: { legend: { labels: { color: '#64748b' } } },
        scales: {
            x: { ticks: { color: '#64748b' }, grid: { color: '#1e293b' } },
            y: { ticks: { color: '#64748b', callback: v => '€' + v }, grid: { color: '#1e293b' } }
        }
    }
});

// ── PAYMENT METHOD CRUD ──
function showCreateMethodModal() {
    Swal.fire({
        title: 'Add Payment Method',
        html: `
            <input id="swal-name" class="swal2-input" placeholder="Name (e.g. Vodafone Cash)">
            <select id="swal-type" class="swal2-select">
                <option value="mobile_wallet">Mobile Wallet</option>
                <option value="bank_transfer">Bank Transfer</option>
                <option value="crypto">Crypto</option>
                <option value="other">Other</option>
            </select>
            <input id="swal-account" class="swal2-input" placeholder="Account/Wallet Number">
            <textarea id="swal-instructions" class="swal2-textarea" placeholder="Instructions for user (optional)"></textarea>
            <input id="swal-min" class="swal2-input" placeholder="Min Amount" type="number" value="10">
            <input id="swal-max" class="swal2-input" placeholder="Max Amount" type="number" value="10000">
        `,
        showCancelButton: true,
        confirmButtonText: 'Create',
        preConfirm: () => {
            const name = document.getElementById('swal-name').value.trim();
            const account_info = document.getElementById('swal-account').value.trim();
            if (!name || !account_info) { Swal.showValidationMessage('Name and account info are required'); return false; }
            return {
                name,
                type: document.getElementById('swal-type').value,
                account_info,
                instructions: document.getElementById('swal-instructions').value.trim(),
                min_amount: parseFloat(document.getElementById('swal-min').value) || 10,
                max_amount: parseFloat(document.getElementById('swal-max').value) || 10000
            };
        }
    }).then(result => {
        if (!result.isConfirmed) return;
        apiPost('create_method', result.value).then(res => {
            if (res.success) Swal.fire('Created!', res.message, 'success').then(() => location.reload());
        });
    });
}

function editMethod(method) {
    Swal.fire({
        title: `Edit: ${method.name}`,
        html: `
            <input id="swal-name" class="swal2-input" placeholder="Name" value="${esc(method.name)}">
            <select id="swal-type" class="swal2-select">
                <option value="mobile_wallet" ${method.type==='mobile_wallet'?'selected':''}>Mobile Wallet</option>
                <option value="bank_transfer" ${method.type==='bank_transfer'?'selected':''}>Bank Transfer</option>
                <option value="crypto" ${method.type==='crypto'?'selected':''}>Crypto</option>
                <option value="other" ${method.type==='other'?'selected':''}>Other</option>
            </select>
            <input id="swal-account" class="swal2-input" placeholder="Account Info" value="${esc(method.account_info)}">
            <textarea id="swal-instructions" class="swal2-textarea" placeholder="Instructions">${esc(method.instructions || '')}</textarea>
            <input id="swal-min" class="swal2-input" type="number" value="${method.min_amount}">
            <input id="swal-max" class="swal2-input" type="number" value="${method.max_amount}">
            <select id="swal-status" class="swal2-select">
                <option value="active" ${method.status==='active'?'selected':''}>Active</option>
                <option value="inactive" ${method.status==='inactive'?'selected':''}>Inactive</option>
            </select>
        `,
        showCancelButton: true,
        confirmButtonText: 'Update',
        preConfirm: () => ({
            method_id: method.id,
            name: document.getElementById('swal-name').value.trim(),
            type: document.getElementById('swal-type').value,
            account_info: document.getElementById('swal-account').value.trim(),
            instructions: document.getElementById('swal-instructions').value.trim(),
            min_amount: parseFloat(document.getElementById('swal-min').value) || 10,
            max_amount: parseFloat(document.getElementById('swal-max').value) || 10000,
            status: document.getElementById('swal-status').value
        })
    }).then(result => {
        if (!result.isConfirmed) return;
        apiPost('update_method', result.value).then(res => {
            if (res.success) Swal.fire('Updated', res.message, 'success').then(() => location.reload());
        });
    });
}

function deleteMethod(id) {
    Swal.fire({
        title: 'Deactivate Method?',
        text: 'Users will no longer see this method. Existing requests are not affected.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Deactivate',
        confirmButtonColor: '#ef4444'
    }).then(result => {
        if (!result.isConfirmed) return;
        apiPost('delete_method', { method_id: id }).then(res => {
            if (res.success) Swal.fire('Done', res.message, 'success').then(() => location.reload());
        });
    });
}

// ── DEPOSIT ACTIONS ──
function loadPending() {
    fetch(API + '?action=deposits&status=pending', { headers }).then(r => r.json()).then(res => {
        if (!res.success) return;
        renderDepositsTable('pendingTableBody', res.deposits, true);
    });
}

function loadHistory(status, btn) {
    if (btn) {
        btn.closest('.d-flex').querySelectorAll('.btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }
    const url = API + '?action=deposits' + (status ? '&status=' + status : '');
    fetch(url, { headers }).then(r => r.json()).then(res => {
        if (!res.success) return;
        renderDepositsTable('historyTableBody', res.deposits, false);
    });
}

function renderDepositsTable(tbodyId, deposits, showActions) {
    const tbody = document.getElementById(tbodyId);
    if (!deposits.length) {
        const cols = showActions ? 8 : 8;
        tbody.innerHTML = `<tr><td colspan="${cols}" class="text-center text-muted py-4">No deposits found</td></tr>`;
        return;
    }
    tbody.innerHTML = deposits.map(d => `
        <tr>
            <td>#${d.id}</td>
            <td><strong>${esc(d.user_name)}</strong></td>
            <td>${esc(d.method_name)}</td>
            <td><strong class="text-gold">€${parseFloat(d.amount).toFixed(2)}</strong></td>
            <td><code>${esc(d.transaction_code)}</code></td>
            ${showActions ? `
                <td>${d.screenshot_path ? `<img src="/bet/uploads/transactions/${esc(d.screenshot_path)}" class="screenshot-thumb" onclick="viewScreenshot('/bet/uploads/transactions/${esc(d.screenshot_path)}')">` : '<span class="text-muted">—</span>'}</td>
                <td>${formatDate(d.created_at)}</td>
                <td>
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-success btn-sm" onclick="approveDeposit(${d.id})"><i class="bi bi-check-lg"></i></button>
                        <button class="btn btn-danger btn-sm" onclick="rejectDeposit(${d.id})"><i class="bi bi-x-lg"></i></button>
                    </div>
                </td>
            ` : `
                <td><span class="badge badge-${d.status}">${d.status.charAt(0).toUpperCase() + d.status.slice(1)}</span></td>
                <td>${formatDate(d.created_at)}</td>
                <td>${d.processed_at ? formatDate(d.processed_at) : '—'}</td>
            `}
        </tr>
    `).join('');
}

function approveDeposit(id) {
    Swal.fire({
        title: 'Approve Deposit?',
        text: 'This will credit the user\'s balance immediately.',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Approve'
    }).then(result => {
        if (!result.isConfirmed) return;
        apiPost('approve_deposit', { request_id: id }).then(res => {
            if (res.success) Swal.fire('Approved!', res.message, 'success').then(() => { loadPending(); location.reload(); });
        });
    });
}

function rejectDeposit(id) {
    Swal.fire({
        title: 'Reject Deposit',
        input: 'textarea',
        inputPlaceholder: 'Reason for rejection (optional)',
        showCancelButton: true,
        confirmButtonText: 'Reject',
        confirmButtonColor: '#ef4444'
    }).then(result => {
        if (!result.isConfirmed) return;
        apiPost('reject_deposit', { request_id: id, reason: result.value }).then(res => {
            if (res.success) Swal.fire('Rejected', res.message, 'info').then(() => { loadPending(); location.reload(); });
        });
    });
}

function viewScreenshot(url) {
    Swal.fire({ imageUrl: url, imageAlt: 'Screenshot', showConfirmButton: false, showCloseButton: true, width: '80%' });
}

// ── HELPERS ──
function esc(str) { const d = document.createElement('div'); d.textContent = str || ''; return d.innerHTML; }
function formatDate(str) { return new Date(str).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); }

async function apiPost(action, data = {}) {
    try {
        const res = await fetch(API, { method: 'POST', headers, body: JSON.stringify({ action, ...data }) });
        const json = await res.json();
        if (!json.success) Swal.fire('Error', json.error || 'Unknown error', 'error');
        return json;
    } catch (e) {
        Swal.fire('Error', 'Network error: ' + e.message, 'error');
        return { success: false };
    }
}
</script>
</body>
</html>
