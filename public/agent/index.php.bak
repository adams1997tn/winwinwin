<?php
/**
 * Agent Panel — Payment method management + Deposit request queue
 */
require_once __DIR__ . '/guard.php';

use App\Admin\PaymentManager;

$paymentMgr = new PaymentManager($db);
$agentId    = $agentUser['id'];

$stats    = $paymentMgr->getAgentDepositStats($agentId);
$methods  = $paymentMgr->getAgentPaymentMethods($agentId);
$pending  = $paymentMgr->getAgentDepositRequests($agentId, 'pending', 50);
$chart    = $paymentMgr->getDepositChartData(7, $agentId);
?>
