</div>

<script>
const API = '/bet/public/api/deposit_api.php';
const ajaxHeaders = { 'Bypass-Tunnel-Reminder': 'true' };
let selectedMethod = null;
let methods = [];

// ── LOAD PAYMENT METHODS ──
async function loadMethods() {
    try {
        const res = await fetch(API + '?action=methods', { headers: ajaxHeaders });
        const data = await res.json();
        if (!data.success) return;
        methods = data.methods;
        renderMethods();
    } catch (e) {
        document.getElementById('methodsGrid').innerHTML = '<div class="col-12 text-center text-danger py-4">Failed to load payment methods</div>';
    }
}

function renderMethods() {
    const grid = document.getElementById('methodsGrid');
    if (!methods.length) {
        grid.innerHTML = '<div class="col-12 text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;opacity:.3"></i><p class="mt-2">No payment methods available at the moment.</p></div>';
        return;
    }
    grid.innerHTML = methods.map(m => `
        <div class="col-md-6 col-lg-4">
            <div class="method-select-card" onclick="selectMethod(${m.id})" id="method-${m.id}">
                <div class="method-type"><i class="bi bi-${getTypeIcon(m.type)}"></i> ${m.type.replace('_', ' ')}</div>
                <div class="method-name mt-1">${esc(m.name)}</div>
                <div class="method-range mt-1">€${parseFloat(m.min_amount).toFixed(0)} — €${parseFloat(m.max_amount).toFixed(0)}</div>
                <div class="small text-muted mt-1">Agent: ${esc(m.agent_name)}</div>
            </div>
        </div>
    `).join('');
}

function getTypeIcon(type) {
    const icons = { mobile_wallet: 'phone', bank_transfer: 'bank', crypto: 'currency-bitcoin', other: 'wallet2' };
    return icons[type] || 'wallet2';
}

function selectMethod(id) {
    selectedMethod = methods.find(m => m.id === id);
    if (!selectedMethod) return;

    // Highlight selected
    document.querySelectorAll('.method-select-card').forEach(c => c.classList.remove('selected'));
    document.getElementById('method-' + id).classList.add('selected');

    // Show instructions
    document.getElementById('selectedMethodId').value = id;
    const instrBox = document.getElementById('instructionsBox');
    instrBox.innerHTML = `
        <div class="mb-2"><strong class="text-gold">${esc(selectedMethod.name)}</strong></div>
        <div class="mb-2"><strong>Account:</strong> <code>${esc(selectedMethod.account_info)}</code>
            <button class="btn btn-sm btn-outline-warning ms-2" onclick="copyText('${esc(selectedMethod.account_info)}')"><i class="bi bi-clipboard"></i></button>
        </div>
        ${selectedMethod.instructions ? `<div class="mt-2">${esc(selectedMethod.instructions).replace(/\n/g, '<br>')}</div>` : ''}
    `;
    document.getElementById('step2').style.display = '';

    // Show form
    const amountInput = document.getElementById('depositAmount');
    amountInput.min = selectedMethod.min_amount;
    amountInput.max = selectedMethod.max_amount;
    document.getElementById('amountRange').textContent = `Min: €${parseFloat(selectedMethod.min_amount).toFixed(2)} — Max: €${parseFloat(selectedMethod.max_amount).toFixed(2)}`;
    document.getElementById('step3').style.display = '';

    // Scroll to instructions
    document.getElementById('step2').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function copyText(text) {
    navigator.clipboard.writeText(text).then(() => {
        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Copied!', showConfirmButton: false, timer: 1500 });
    });
}

// ── SCREENSHOT UPLOAD ──
const uploadZone = document.getElementById('uploadZone');
const screenshotInput = document.getElementById('screenshotInput');
const screenshotPreview = document.getElementById('screenshotPreview');

if (uploadZone) {
    uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('dragover'); });
    uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
    uploadZone.addEventListener('drop', e => {
        e.preventDefault();
        uploadZone.classList.remove('dragover');
        if (e.dataTransfer.files.length) {
            screenshotInput.files = e.dataTransfer.files;
            previewFile(e.dataTransfer.files[0]);
        }
    });
    screenshotInput.addEventListener('change', () => {
        if (screenshotInput.files.length) previewFile(screenshotInput.files[0]);
    });
}

function previewFile(file) {
    if (file.size > 5 * 1024 * 1024) {
        Swal.fire('Error', 'File too large. Maximum 5MB.', 'error');
        screenshotInput.value = '';
        return;
    }
    const reader = new FileReader();
    reader.onload = e => {
        screenshotPreview.src = e.target.result;
        screenshotPreview.style.display = '';
    };
    reader.readAsDataURL(file);
}

// ── SUBMIT DEPOSIT ──
const depositForm = document.getElementById('depositForm');
if (depositForm) {
    depositForm.addEventListener('submit', async e => {
        e.preventDefault();
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-arrow-clockwise spin"></i> Submitting...';

        const formData = new FormData(depositForm);
        formData.append('action', 'submit_deposit');

        try {
            const res = await fetch(API, {
                method: 'POST',
                headers: { 'Bypass-Tunnel-Reminder': 'true' },
                body: formData
            });
            const data = await res.json();

            if (data.success) {
                Swal.fire('Success!', data.message, 'success');
                depositForm.reset();
                screenshotPreview.style.display = 'none';
                selectedMethod = null;
                document.querySelectorAll('.method-select-card').forEach(c => c.classList.remove('selected'));
                document.getElementById('step2').style.display = 'none';
                document.getElementById('step3').style.display = 'none';
                loadHistory();
            } else {
                Swal.fire('Error', data.error || 'Failed to submit deposit', 'error');
            }
        } catch (err) {
            Swal.fire('Error', 'Network error: ' + err.message, 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-send-fill"></i> Submit Deposit Request';
        }
    });
}

// ── DEPOSIT HISTORY ──
async function loadHistory() {
    try {
        const res = await fetch(API + '?action=history', { headers: ajaxHeaders });
        const data = await res.json();
        if (!data.success) return;

        const tbody = document.getElementById('historyTableBody');
        if (!data.deposits.length) {
            tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4">No deposit history yet</td></tr>';
            return;
        }
        tbody.innerHTML = data.deposits.map(d => `
            <tr>
                <td>#${d.id}</td>
                <td>${esc(d.method_name)}</td>
                <td><strong>€${parseFloat(d.amount).toFixed(2)}</strong></td>
                <td><code>${esc(d.transaction_code)}</code></td>
                <td><span class="badge badge-${d.status}">${d.status.charAt(0).toUpperCase() + d.status.slice(1)}</span></td>
                <td>${new Date(d.created_at).toLocaleDateString('en-GB', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})}</td>
                <td>${d.status === 'rejected' && d.rejection_reason ? `<span class="text-danger small">${esc(d.rejection_reason)}</span>` : '—'}</td>
            </tr>
        `).join('');
    } catch (e) {
        console.error('Failed to load history:', e);
    }
}

// ── HELPERS ──
function esc(str) { const d = document.createElement('div'); d.textContent = str || ''; return d.innerHTML; }

// ── INIT ──
<?php if ($loggedIn): ?>
loadMethods();
loadHistory();
<?php endif; ?>
</script>
</body>
</html>
